<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.UserPreferenceMemoryMapper">

    <resultMap id="UserPreferenceMemoryResultMap" type="com.example.entity.UserPreferenceMemory">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="preferenceContent" column="preference_content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectById" resultMap="UserPreferenceMemoryResultMap">
        SELECT * FROM user_preference_memory WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="UserPreferenceMemoryResultMap">
        SELECT * FROM user_preference_memory WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="selectAll" resultMap="UserPreferenceMemoryResultMap">
        SELECT * FROM user_preference_memory ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="com.example.entity.UserPreferenceMemory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_preference_memory (user_id, preference_content, created_at)
        VALUES (#{userId}, #{preferenceContent}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM user_preference_memory WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM user_preference_memory WHERE user_id = #{userId}
    </delete>

</mapper>
